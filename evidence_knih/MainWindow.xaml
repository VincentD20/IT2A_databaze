<Window x:Class="evidence_knih.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:evidence_knih"
        mc:Ignorable="d"
        Title="Evidence cviků" 
        Height="480" 
        Width="880"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Datagrid – seznam knih -->
        <DataGrid x:Name="SkillsDataGrid"
                  Grid.Column="0"
                  Margin="0,0,12,0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  AlternatingRowBackground="#F5F7FA"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E0E0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Název"    Binding="{Binding Nazev}"    Width="*"     MinWidth="100"/>
                <DataGridTextColumn Header="Kategorie"    Binding="{Binding Kategorie}"   Width="*"     MinWidth="100"/>
                <DataGridTextColumn Header="Obtížnost"     Binding="{Binding Obtiznost}"     Width="*" MinWidth="80"/>
                <DataGridTextColumn Header="Počet týdnů"      Binding="{Binding Tydny}" Width="*" MinWidth="80"/>
                <DataGridTextColumn Header="Poznámka"       Binding="{Binding Poznamka}" Width="*" MinWidth="100"/>
                <DataGridCheckBoxColumn Header="Zvládnuto" Binding="{Binding Splneno}" Width="*" MinWidth="20"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Pravý panel – formulář -->
        <Border Grid.Column="1" 
                Background="#F8F9FA" 
                BorderBrush="#D0D7E0" 
                BorderThickness="1" 
                CornerRadius="6"
                Padding="16">

            <StackPanel>

                <TextBlock Text="Skills" 
                           FontWeight="SemiBold" 
                           FontSize="16" 
                           Margin="0,0,0,16"/>

                <Label Content="Název" Margin="0,0,0,4"/>
                <TextBox x:Name="Nazev" MaxLength="150"/>

                <Label Content="Kategorie" Margin="0,0,0,4"/>
                <TextBox x:Name="Kategorie" MaxLength="100"/>

                <Label Content="Obtížnost" Margin="0,0,0,4"/>
                <TextBox x:Name="Obtiznost" MaxLength="4"/>

                <Label Content="Počet týdnů" Margin="0,0,0,4"/>
                <TextBox x:Name="Pocet_tydnu" MaxLength="80"/>

                <Label Content="Poznámka" Margin="0,0,0,4"/>
                <TextBox x:Name="Poznamka" MaxLength="80" />

                <Label Content="Zvládnuto" Margin="0,0,0,4"/>
                <CheckBox x:Name="Splneno" Margin="0,0,0,12"/>

                <!-- Tlačítka vedle sebe -->
                <UniformGrid Rows="1" HorizontalAlignment="Stretch">
                    <Button x:Name="BtnAdd"    Content="Přidat"    Width="Auto" Margin="0,0,8,0" Click="BtnAdd_Click"/>
                    <Button x:Name="BtnEdit"   Content="Upravit"   Width="Auto" Margin="0,0,8,0" Click="BtnEdit_Click"   />
                    <Button x:Name="BtnDelete" Content="Smazat"    Width="Auto" Margin="0,0,8,0" Click="BtnDelete_Click" />
                </UniformGrid>

            </StackPanel>
        </Border>
    </Grid>
</Window>